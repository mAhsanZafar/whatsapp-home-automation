        "\n",
        "    # Gradients for output layer parameters with L2 derivative\n",
        "    A_prev_output_layer = caches[f'A{hidden_layers}']\n",
        "    grads[f'dW{hidden_layers + 1}'] = np.dot(dZ_out, A_prev_output_layer.T) / m_batch + (lambda_val / m_batch) * parameters[f'W{hidden_layers + 1}']\n",
        "    grads[f'db{hidden_layers + 1}'] = np.sum(dZ_out, axis=1, keepdims=True) / m_batch\n",
        "\n",
        "    # Backpropagate through hidden layers with L2 derivative\n",
        "    dA_prev = np.dot(parameters[f'W{hidden_layers + 1}'].T, dZ_out)\n",
        "\n",
        "    for l in reversed(range(1, hidden_layers + 1)):\n",
