        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# --- Helper functions (re-defined for self-containment) ---\n",
        "# Activation functions\n",
        "def sigmoid(x):\n",
        "    return 1 / (1 + np.exp(-x))\n",
        "\n",
        "def sigmoid_derivative(x):\n",
        "    s = sigmoid(x)\n",
        "    return s * (1 - s)\n",
        "\n",
        "def relu(x):\n",
        "    return np.maximum(0, x)\n",
        "\n",
        "def relu_derivative(x):\n",
        "    return (x > 0).astype(float)\n",
        "\n",
        "# Parameter initialization (He initialization for hidden layers)\n",
        "def initialize_parameters(input_size, hidden_layer_sizes, output_size):\n",
        "    parameters = {}\n",
        "    layer_dims = [input_size] + hidden_layer_sizes + [output_size]\n",
        "\n",
        "    for l in range(1, len(layer_dims)):\n",
        "        if l < len(layer_dims) - 1: # Hidden layers (ReLU activation)\n",
        "            parameters[f'W{l}'] = np.random.randn(layer_dims[l], layer_dims[l-1]) * np.sqrt(2 / layer_dims[l-1])\n",
        "        else: # Output layer (Sigmoid activation)\n",
        "            parameters[f'W{l}'] = np.random.randn(layer_dims[l], layer_dims[l-1]) * 0.01\n",
        "        parameters[f'b{l}'] = np.zeros((layer_dims[l], 1))\n",
        "\n",
        "    return parameters\n",
        "\n",
        "# Forward propagation\n",
        "def forward_propagation(X, parameters, hidden_layers):\n",
        "    caches = {}\n",
        "    A_prev = X.T # Transpose X to (n_features, n_samples)\n",
        "    caches['A0'] = A_prev # Store A0 (input activations)\n",
        "\n",
        "    for l in range(1, hidden_layers + 1):\n",
        "        W = parameters[f'W{l}']\n",
        "        b = parameters[f'b{l}']\n",
        "\n",
        "        Z = np.dot(W, A_prev) + b\n",
        "        A = relu(Z)\n",
        "\n",
        "        caches[f'Z{l}'] = Z\n",
        "        caches[f'A{l}'] = A\n",
        "        A_prev = A\n",
        "\n",
        "    W_out = parameters[f'W{hidden_layers + 1}']\n",
        "    b_out = parameters[f'b{hidden_layers + 1}']\n",
        "\n",
        "    Z_out = np.dot(W_out, A_prev) + b_out\n",
        "    A_out = sigmoid(Z_out) # Sigmoid for output layer\n",
        "\n",
        "    caches[f'Z{hidden_layers + 1}'] = Z_out\n",
        "    caches[f'A{hidden_layers + 1}'] = A_out\n",
        "\n",
        "    return A_out, caches\n",
        "\n",
        "# Cost calculation with L2 regularization\n",
        "def compute_cost(A_raw, Y_true, parameters, lambda_val, hidden_layers):\n",
        "    A = A_raw[1, :].reshape(1, -1) # Probabilities for class 1\n",
        "    Y = Y_true.reshape(1, -1)\n",
        "    m = Y.shape[1]\n",
        "    epsilon = 1e-8\n",
        "\n",
        "    cross_entropy_cost = (-1 / m) * np.sum(Y * np.log(A + epsilon) + (1 - Y) * np.log(1 - A + epsilon))\n",
        "\n",
        "    l2_regularization_cost = 0\n",
        "    for l in range(1, hidden_layers + 2): # Iterate through all layers including output\n",
        "        l2_regularization_cost += np.sum(np.square(parameters[f'W{l}']))\n",
        "    l2_regularization_cost = (lambda_val / (2 * m)) * l2_regularization_cost\n",
        "\n",
        "    total_cost = cross_entropy_cost + l2_regularization_cost\n",
        "    return np.squeeze(total_cost)\n",
        "\n",
        "# Backward propagation with L2 regularization derivative\n",
        "def backward_propagation(A_out, Y, caches, parameters, hidden_layers, lambda_val):\n",
        "    grads = {}\n",
        "    m_batch = Y.shape[0]\n",
        "    Y = Y.reshape(1, m_batch)\n",
        "\n",
        "    # Output layer gradient\n",
        "    dZ_out_full = np.zeros_like(A_out)\n",
        "    dZ_out_full[1, :] = (A_out[1, :].reshape(1, -1) - Y)\n",
        "    dZ_out = dZ_out_full\n",
        "\n",
        "    # Gradients for output layer parameters with L2 derivative\n",
        "    A_prev_output_layer = caches[f'A{hidden_layers}']\n",
        "    grads[f'dW{hidden_layers + 1}'] = np.dot(dZ_out, A_prev_output_layer.T) / m_batch + (lambda_val / m_batch) * parameters[f'W{hidden_layers + 1}']\n",
        "    grads[f'db{hidden_layers + 1}'] = np.sum(dZ_out, axis=1, keepdims=True) / m_batch\n",
        "\n",
        "    # Backpropagate through hidden layers with L2 derivative\n",
        "    dA_prev = np.dot(parameters[f'W{hidden_layers + 1}'].T, dZ_out)\n",
        "\n",
        "    for l in reversed(range(1, hidden_layers + 1)):\n",
        "        W_current = parameters[f'W{l}']\n",
        "        Z_current = caches[f'Z{l}']\n",
        "        A_prev_cache = caches[f'A{l-1}']\n",
        "\n",
        "        dZ_current = dA_prev * relu_derivative(Z_current)\n",
        "\n",
        "        grads[f'dW{l}'] = np.dot(dZ_current, A_prev_cache.T) / m_batch + (lambda_val / m_batch) * W_current\n",
        "        grads[f'db{l}'] = np.sum(dZ_current, axis=1, keepdims=True) / m_batch\n",
        "\n",
        "        if l > 1:\n",
        "            dA_prev = np.dot(W_current.T, dZ_current)\n",
        "\n",
        "    return grads\n",
        "\n",
        "# Parameter update\n",
