        "# Backward propagation - MODIFIED to accept hidden_activation_derivative_fn\n",
        "def backward_propagation_dynamic_activation(A_out, Y, caches, parameters, hidden_layers, lambda_val, hidden_activation_derivative_fn):\n",
        "    grads = {}\n",
        "    m_batch = Y.shape[0]\n",
